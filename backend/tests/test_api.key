import pytest
from fastapi.testclient import TestClient
from app.main import app
from app.database import get_db, engine
from app import models

models.Base.metadata.create_all(bind=engine)
client = TestClient(app)

def get_token(email, password):
    r = client.post("/auth/login", data={"username": email, "password": password})
    return r.json()["access_token"]

def test_register_and_login():
    client.post("/auth/register", json={"email": "test@test.com", "password": "pass123"})
    r = client.post("/auth/login", data={"username": "test@test.com", "password": "pass123"})
    assert r.status_code == 200
    assert "access_token" in r.json()

def test_reviewer_cannot_see_other_scores():
    # Register two reviewers
    client.post("/auth/register", json={"email": "rev1@test.com", "password": "pass"})
    client.post("/auth/register", json={"email": "rev2@test.com", "password": "pass"})
    token1 = get_token("rev1@test.com", "pass")
    token2 = get_token("rev2@test.com", "pass")
    headers1 = {"Authorization": f"Bearer {token1}"}
    headers2 = {"Authorization": f"Bearer {token2}"}
    # rev1 scores candidate 1 (create candidate first via admin or direct DB)
    # Then rev2 fetches candidate 1 — should not see rev1's scores
    r = client.get("/candidates/1", headers=headers2)
    if r.status_code == 200:
        scores = r.json().get("scores", [])
        # All scores in response must belong to rev2, not rev1
        assert all(s["reviewer_id"] != 1 for s in scores)

def test_unauthenticated_request_blocked():
    r = client.get("/candidates/")
    assert r.status_code == 401